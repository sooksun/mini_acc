# ============================================================
# HJ Account AI — Production environment template
# ============================================================
#
# Copy this file to .env.production, fill in the secrets, then:
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d
#
# DO NOT COMMIT .env.production to git. It contains real secrets.
#
# ============================================================

# --- Database (MariaDB 11, internal) -------------------------
DB_NAME=hjacc
DB_USER=hjacc
# Generate: openssl rand -base64 24
DB_PASSWORD=REPLACE-WITH-STRONG-DB-PASSWORD
# Generate: openssl rand -base64 24
DB_ROOT_PASSWORD=REPLACE-WITH-STRONG-ROOT-PASSWORD

# --- Auth ---------------------------------------------------
# Generate: openssl rand -base64 48
JWT_SECRET=REPLACE-WITH-OPENSSL-RAND-BASE64-48-OUTPUT
JWT_EXPIRES_IN=12h

# --- Public URLs --------------------------------------------
# The origin browsers will load the web app from (used for CORS allow-list).
# Production: https://accounting.cnppai.com (TLS terminated at Nginx Proxy Manager)
WEB_ORIGIN=https://accounting.cnppai.com

# Where the browser sends API calls. With NPM proxying the same hostname for
# both / and /api/, leave EMPTY so the bundle uses relative /api/... paths.
NEXT_PUBLIC_API_URL=

# --- AI gateway (optional — AI Inbox feature) ---------------
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL_EXTRACT=anthropic/claude-sonnet-4
OPENROUTER_MODEL_CLASSIFY=anthropic/claude-haiku-4
# Request timeout for OpenRouter calls (ms). Falls back to mock on timeout.
OPENROUTER_TIMEOUT_MS=30000
# Set to "1" to skip OpenRouter calls entirely (mock-only). For customers with
# strict data-egress policies or to triage a billing issue.
AI_INBOX_DISABLED=0

# --- Uploads ------------------------------------------------
MAX_UPLOAD_MB=20
