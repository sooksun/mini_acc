node_modules
.pnpm-store
dist
.next
.turbo
out
build

.env
.env.*
!.env.example
!.env.test.example
!.env.production.example
.env.production
.env_backup

# Claude Code agent worktrees / local cache — never commit
.claude/

# Production backups (volume-mounted into backup container)
backup/*.sql
backup/*.sql.gz
!backup/.gitkeep

# nginx TLS certificates — never commit private keys
nginx/certs/*.pem
nginx/certs/*.key
!nginx/certs/.gitkeep

*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

.DS_Store
Thumbs.db

coverage
.nyc_output

# Runtime / local output (attachments, PDFs, manual screenshots, smoke reports)
var/
# api ephemeral output (test attachments, generated/sample PDFs)
apps/api/var/

# Cursor MCP tool descriptors — local IDE config, not part of the app
mcps/

# Dev-only manual QA / E2E loop scripts (not shipped with the product)
apps/api/scripts/manual-*.ts
apps/api/scripts/e2e-smoke-loop.ts
storage/
*.tsbuildinfo

# apps/web/public/ is served UNAUTHENTICATED — deny by default, then allowlist only the
# static assets that belong in the web bundle. Anything else dropped here (generated *.pdf,
# ad-hoc downloads, oversized source art) stays out of git automatically.
apps/web/public/*
!apps/web/public/.gitkeep
!apps/web/public/logo.png
!apps/web/public/favicon.ico
!apps/web/public/favicon-16x16.png
!apps/web/public/favicon-32x32.png
!apps/web/public/apple-touch-icon.png
!apps/web/public/android-chrome-192x192.png
!apps/web/public/android-chrome-512x512.png
!apps/web/public/site.webmanifest

# never commit archives anywhere in the repo (handoff bundles, favicon-generator downloads)
*.zip

prisma/migrations/dev.db*
