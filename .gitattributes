# Default: auto-detect, normalize to LF in repo
* text=auto eol=lf

# Force LF for shell scripts + Docker files that run inside Linux containers
*.sh           text eol=lf
Dockerfile*    text eol=lf
*.conf         text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf

# Binary files — never touch
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.ico          binary
*.pdf          binary
*.woff         binary
*.woff2        binary
*.ttf          binary
*.otf          binary
*.zip          binary
*.gz           binary
*.sql.gz       binary
