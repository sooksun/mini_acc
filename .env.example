DATABASE_URL="mysql://root@localhost:3306/hjacc"
REDIS_URL="redis://localhost:6379"

JWT_SECRET="REPLACE-WITH-OPENSSL-RAND-BASE64-48-OUTPUT-DO-NOT-COMMIT"
JWT_EXPIRES_IN="12h"

API_PORT=4000
WEB_PORT=3000
WEB_ORIGIN="http://localhost:3000"

OPENROUTER_API_KEY=""
OPENROUTER_MODEL_EXTRACT="anthropic/claude-sonnet-4"
OPENROUTER_MODEL_CLASSIFY="anthropic/claude-haiku-4"

# Filesystem root for uploaded attachments (expense receipts, etc.).
# Subfolders are created per-feature/per-companyId underneath.
ATTACHMENT_DIR="./var/attachments"
# Max upload size (MB) — applied by FileInterceptor on /expense-receipts/upload.
MAX_UPLOAD_MB=20

NODE_ENV="development"
TZ="Asia/Bangkok"

NEXT_PUBLIC_API_URL="http://localhost:4000"
