DATABASE_URL="mysql://root@localhost:3306/hjacc_test"

JWT_SECRET="test-only-fixed-secret-do-not-use-in-prod-aaaaaa"
JWT_EXPIRES_IN="1h"

ATTACHMENT_DIR="./var/test-attachments"
MAX_UPLOAD_MB=20

NODE_ENV="test"
TZ="Asia/Bangkok"

# Force the AI extractor to use the deterministic mock (no network egress).
# Without this, ConfigModule loads the root .env's real OPENROUTER_API_KEY and
# the integration suite would make live OpenRouter calls (non-deterministic).
AI_INBOX_DISABLED=1
