{
  "name": "@hj/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "dotenv -e ../../.env -- nest start --watch",
    "build": "nest build",
    "start": "dotenv -e ../../.env -- node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "dotenv -e .env.test -- jest --runInBand",
    "test:unit": "dotenv -e .env.test -- jest --runInBand --testPathIgnorePatterns=integration",
    "test:integration": "dotenv -e .env.test -- jest --runInBand --testPathPattern=integration",
    "test:db:setup": "dotenv -e .env.test -- prisma migrate deploy",
    "prisma:generate": "dotenv -e ../../.env -- prisma generate",
    "prisma:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "prisma:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "prisma:seed": "dotenv -e ../../.env -- prisma db seed",
    "prisma:studio": "dotenv -e ../../.env -- prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hj/shared-types": "workspace:*",
    "@nestjs/bullmq": "10.2.3",
    "@nestjs/common": "10.4.7",
    "@nestjs/config": "3.3.0",
    "@nestjs/core": "10.4.7",
    "@nestjs/jwt": "10.2.0",
    "@nestjs/passport": "10.0.3",
    "@nestjs/platform-express": "10.4.7",
    "@prisma/client": "5.22.0",
    "argon2": "0.41.1",
    "bullmq": "5.30.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "helmet": "8.0.0",
    "ioredis": "5.4.1",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "playwright": "1.49.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.7",
    "@nestjs/schematics": "10.2.3",
    "@nestjs/testing": "10.4.7",
    "@types/express": "5.0.0",
    "@types/jest": "29.5.14",
    "@types/node": "20.17.6",
    "@types/passport-jwt": "4.0.1",
    "dotenv-cli": "8.0.0",
    "jest": "29.7.0",
    "prisma": "5.22.0",
    "ts-jest": "29.2.5",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  }
}
