generator client {
  provider = "prisma-client-js"
  // "native" — for local dev (Windows / macOS dev machine).
  // "debian-openssl-3.0.x" — for the production Docker runner (Playwright
  //   image runs on Ubuntu 22.04+, which ships OpenSSL 3.0). Without this,
  //   Prisma generates only the builder-image binary (Debian bookworm slim
  //   = OpenSSL 1.1) and the runner crashes on startup with
  //   "could not locate the Query Engine for runtime debian-openssl-3.0.x".
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  ACCOUNTANT
  VIEWER
  AI_AGENT
}

enum VatStatus {
  NOT_REGISTERED
  REGISTERED
  CANCELLED
}

enum DocumentType {
  QUOTATION
  DELIVERY_NOTE
  INVOICE
  RECEIPT
  TAX_INVOICE
  RECEIPT_TAX_INVOICE
  PURCHASE
  EXPENSE
  WHT_CERTIFICATE
  BANK_STATEMENT
}

enum NumberingResetPolicy {
  YEARLY
  NEVER
}

enum DocumentStatus {
  DRAFT
  AI_EXTRACTED
  PENDING_REVIEW
  USER_CONFIRMED
  ACCOUNTED
  PENDING_ACCOUNTANT
  ACCOUNTANT_APPROVED
  LOCKED
  VOIDED
}

enum PartnerType {
  CUSTOMER
  VENDOR
  BOTH
}

enum VendorCategory {
  SHOP
  CONTRACTOR
  EMPLOYEE
  FREELANCE
  GOVERNMENT
  OTHER
}

enum ProductType {
  GOOD
  SERVICE
  MATERIAL
  ASSET
}

enum AttachmentTargetType {
  SALES_DOCUMENT
  PURCHASE_DOCUMENT
  PAYMENT
  EXPENSE
  OTHER
}

enum ExpenseReceiptStatus {
  UPLOADED
  PENDING_VENDOR_APPROVAL
  READY_TO_ACCOUNT
  ACCOUNTED
  REJECTED
}

enum ExpenseRecordStatus {
  RECORDED
  VOIDED
}

enum PaymentDirection {
  IN
  OUT
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  CREDIT_CARD
  PROMPT_PAY
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  VOIDED
}

enum AccountingPeriodStatus {
  OPEN
  CLOSING
  LOCKED
  REOPENED
}

enum JournalSourceType {
  SALES_DOCUMENT
  EXPENSE_RECORD
  PAYMENT
  INVENTORY_MOVEMENT
  FIXED_ASSET
  MANUAL
  ADJUSTMENT
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  VOIDED
}

enum VatRecordType {
  OUTPUT
  INPUT
}

enum WhtRecordType {
  PAYABLE
  RECEIVABLE
}

enum ExpenseNature {
  GOODS
  SERVICE
}

enum ForeignTaxKind {
  PP36_VAT
  PND54_WHT
}

enum ForeignTaxStatus {
  PENDING
  FILED
  CREDITED
}

enum ForeignWhtType {
  ROYALTY
  SERVICE
  OTHER
}

enum ForeignWhtBorneBy {
  WITHHELD // หักจากเงินที่จ่ายผู้ขาย (ผู้ขายได้ยอดสุทธิ)
  RECOVERABLE // จ่ายเต็ม แล้วเรียกคืนภาษีจากผู้ขาย (ลูกหนี้อื่น)
  GROSSED_UP // กิจการรับภาระภาษีเอง (gross-up ฐาน = สุทธิ/(1-rate))
}

enum PrepaidScheduleStatus {
  PENDING // รอตัดเข้าค่าใช้จ่าย
  RECOGNIZED // ตัดเข้าค่าใช้จ่าย (ลง journal) แล้ว
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskItemType {
  MISSING_DOCUMENT
  DUPLICATE_DOCUMENT
  VAT_RISK
  WHT_RISK
  UNMATCHED_BANK
  LOW_PROFIT_PROJECT
  STOCK_NEGATIVE
  EXPENSE_WITHOUT_APPROVAL
  EDIT_AFTER_CONFIRM
  TAX_ID_MISSING
  PDF_GENERATION_ERROR
}

enum RiskItemStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  ACCEPTED_RISK
  DISMISSED
}

enum AiSuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
  OVERRIDDEN
}

enum AiSuggestionType {
  DOCUMENT_EXTRACT
  ACCOUNT_CLASSIFY
  BANK_MATCH
  RISK_FLAG
  MONTHLY_SUMMARY
}

enum InventoryMovementType {
  IN
  OUT
  ADJUST
  RETURN_IN
  RETURN_OUT
  OPENING_BALANCE
}

enum FixedAssetStatus {
  ACTIVE
  DISPOSED
  WRITTEN_OFF
}

enum BankStatementSide {
  DEBIT
  CREDIT
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

model Company {
  id               String    @id @default(cuid())
  nameTh           String
  nameEn           String?
  taxId            String    @unique
  address          String    @db.Text
  phone            String?
  email            String?
  brandShort       String?
  tagline          String?
  registeredAt     DateTime
  vatEffectiveDate DateTime?
  capital          Decimal?  @db.Decimal(18, 2)

  vatStatuses        CompanyVatStatus[]
  users              User[]
  auditLogs          AuditLog[]
  numberingRules     DocumentNumberingRule[]
  numberingCounters  DocumentNumberingCounter[]
  partners           Partner[]
  products           Product[]
  salesDocuments     SalesDocument[]
  expenseReceipts    ExpenseReceipt[]
  expenseRecords     ExpenseRecord[]
  attachments        Attachment[]
  generatedPdfs      GeneratedPdf[]
  projects           Project[]
  payments           Payment[]
  journalEntries     JournalEntry[]
  accountingPeriods  AccountingPeriod[]
  vatRecords         VatRecord[]
  whtRecords         WithholdingTaxRecord[]
  riskItems          RiskItem[]
  aiSuggestions      AiSuggestion[]
  inventoryMovements InventoryMovement[]
  fixedAssets        FixedAsset[]
  bankStatementLines BankStatementLine[]
  foreignTaxObligations ForeignTaxObligation[]
  prepaidScheduleEntries PrepaidScheduleEntry[]
  exportBatches      ExportBatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyVatStatus {
  id            String    @id @default(cuid())
  companyId     String
  status        VatStatus
  effectiveFrom DateTime
  effectiveTo   DateTime?
  reason        String?   @db.Text

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([companyId, effectiveFrom])
}

model User {
  id           String  @id @default(cuid())
  companyId    String
  email        String  @unique
  passwordHash String
  fullName     String
  initial      String?
  role         Role
  isActive     Boolean @default(true)

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  auditLogs AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model AuditLog {
  id         String  @id @default(cuid())
  companyId  String
  userId     String?
  action     String
  entityType String?
  entityId   String?
  reason     String? @db.Text
  metadata   Json?
  ipAddress  String?
  userAgent  String? @db.Text

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([entityType, entityId])
  @@index([action])
}

model DocumentNumberingRule {
  id          String               @id @default(cuid())
  companyId   String
  type        DocumentType
  prefix      String               @db.VarChar(8)
  padding     Int                  @default(4)
  resetPolicy NumberingResetPolicy @default(YEARLY)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, type])
}

model DocumentNumberingCounter {
  id           String       @id @default(cuid())
  companyId    String
  type         DocumentType
  beYear       Int
  currentValue Int          @default(0)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@unique([companyId, type, beYear])
  @@index([companyId, type, beYear])
}

model Partner {
  id             String          @id @default(cuid())
  companyId      String
  type           PartnerType     @default(CUSTOMER)
  vendorCategory VendorCategory?
  code           String?         @db.VarChar(32)
  nameTh         String          @db.VarChar(200)
  nameEn         String?         @db.VarChar(200)
  taxId          String?         @db.VarChar(20)
  branch         String?         @db.VarChar(50)
  address        String?         @db.Text
  phone          String?         @db.VarChar(50)
  email          String?         @db.VarChar(120)
  website        String?         @db.VarChar(200)
  note           String?         @db.Text
  defaultWhtRate Decimal?        @db.Decimal(5, 2)
  isActive       Boolean         @default(true)

  company                 Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contacts                PartnerContact[]
  asCustomerSalesDocs     SalesDocument[]  @relation("SalesDocumentCustomer")
  asVendorExpenseReceipts ExpenseReceipt[] @relation("ExpenseReceiptVendor")
  asVendorExpenseRecords  ExpenseRecord[]  @relation("ExpenseRecordVendor")
  payments                Payment[]        @relation("PaymentPartner")
  asCustomerProjects      Project[]        @relation("ProjectCustomer")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, code])
  @@index([companyId, type, isActive])
  @@index([companyId, taxId])
}

model PartnerContact {
  id        String  @id @default(cuid())
  partnerId String
  name      String  @db.VarChar(200)
  position  String? @db.VarChar(100)
  phone     String? @db.VarChar(50)
  email     String? @db.VarChar(120)
  isPrimary Boolean @default(false)

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([partnerId])
}

model Product {
  id          String      @id @default(cuid())
  companyId   String
  type        ProductType @default(SERVICE)
  code        String?     @db.VarChar(32)
  nameTh      String      @db.VarChar(200)
  nameEn      String?     @db.VarChar(200)
  description String?     @db.Text
  unit        String      @db.VarChar(32)
  unitPrice   Decimal     @db.Decimal(18, 2)
  vatable     Boolean     @default(true)
  isActive    Boolean     @default(true)

  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  salesItems         SalesDocumentItem[]
  inventoryMovements InventoryMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, code])
  @@index([companyId, type, isActive])
}

model SalesDocument {
  id        String         @id @default(cuid())
  companyId String
  type      DocumentType
  number    String         @db.VarChar(40)
  beYear    Int
  status    DocumentStatus @default(DRAFT)

  customerId String
  projectId  String?

  parentDocumentId String?
  parentDocument   SalesDocument?  @relation("SalesDocumentChain", fields: [parentDocumentId], references: [id])
  childDocuments   SalesDocument[] @relation("SalesDocumentChain")

  documentDate DateTime
  dueDate      DateTime?
  reference    String?   @db.VarChar(100)
  note         String?   @db.Text

  customerSnapshotName    String  @db.VarChar(200)
  customerSnapshotAddress String? @db.Text
  customerSnapshotTaxId   String? @db.VarChar(20)
  customerSnapshotBranch  String? @db.VarChar(50)

  subtotal      Decimal @default(0) @db.Decimal(18, 2)
  vatRate       Decimal @default(7) @db.Decimal(5, 2)
  vatAmount     Decimal @default(0) @db.Decimal(18, 2)
  totalAfterVat Decimal @default(0) @db.Decimal(18, 2)
  whtRate       Decimal @default(0) @db.Decimal(5, 2)
  whtAmount     Decimal @default(0) @db.Decimal(18, 2)
  grandTotal    Decimal @default(0) @db.Decimal(18, 2)
  netReceived   Decimal @default(0) @db.Decimal(18, 2)

  confirmedAt DateTime?
  confirmedBy String?
  voidedAt    DateTime?
  voidedBy    String?
  voidReason  String?   @db.Text
  lockedAt    DateTime?
  lockedBy    String?

  pdfPath        String?   @db.VarChar(500)
  pdfGeneratedAt DateTime?
  pdfGeneratedBy String?

  company  Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Partner             @relation("SalesDocumentCustomer", fields: [customerId], references: [id])
  items    SalesDocumentItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@unique([companyId, type, number])
  @@index([companyId, type, status, documentDate])
  @@index([companyId, customerId])
  @@index([companyId, status])
  @@index([beYear, type])
}

model SalesDocumentItem {
  id              String  @id @default(cuid())
  salesDocumentId String
  productId       String?
  lineNumber      Int

  productCode String? @db.VarChar(32)
  description String  @db.Text
  unit        String  @db.VarChar(32)
  quantity    Decimal @db.Decimal(18, 4)
  unitPrice   Decimal @db.Decimal(18, 2)
  discount    Decimal @default(0) @db.Decimal(18, 2)
  lineTotal   Decimal @db.Decimal(18, 2)
  vatable     Boolean @default(true)

  salesDocument SalesDocument @relation(fields: [salesDocumentId], references: [id], onDelete: Cascade)
  product       Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([salesDocumentId, lineNumber])
  @@index([salesDocumentId])
}

model Attachment {
  id         String               @id @default(cuid())
  companyId  String
  targetType AttachmentTargetType
  targetId   String
  fileName   String               @db.VarChar(300)
  storedPath String               @db.VarChar(500)
  mimeType   String               @db.VarChar(100)
  sizeBytes  Int
  sha256     String?              @db.VarChar(64)
  uploadedBy String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([companyId, targetType, targetId])
  @@index([sha256])
}

model ExpenseReceipt {
  id        String               @id @default(cuid())
  companyId String
  status    ExpenseReceiptStatus @default(UPLOADED)

  vendorId String?
  vendor   Partner? @relation("ExpenseReceiptVendor", fields: [vendorId], references: [id])

  proposedVendorName    String? @db.VarChar(200)
  proposedVendorTaxId   String? @db.VarChar(20)
  proposedVendorBranch  String? @db.VarChar(50)
  proposedVendorAddress String? @db.Text

  documentNumber String?   @db.VarChar(100)
  documentDate   DateTime?
  paidAt         DateTime?
  category       String?   @db.VarChar(100)
  note           String?   @db.Text

  subtotal             Decimal @default(0) @db.Decimal(18, 2)
  vatAmount            Decimal @default(0) @db.Decimal(18, 2)
  withholdingTaxAmount Decimal @default(0) @db.Decimal(18, 2)
  grandTotal           Decimal @default(0) @db.Decimal(18, 2)

  // Foreign expense (PP.36 / PND.54). Domestic rows keep defaults.
  // subtotal/vatAmount/grandTotal stay THB; the fields below add the original
  // currency, the FX rate used, and the self-assessed VAT (PP.36) intent.
  isForeign            Boolean        @default(false)
  expenseNature        ExpenseNature?
  usedInThailand       Boolean        @default(true)
  currency             String         @default("THB") @db.VarChar(3)
  fxRate               Decimal        @default(1) @db.Decimal(18, 6)
  foreignSubtotal      Decimal?       @db.Decimal(18, 2)
  reverseChargeVat     Boolean        @default(false)
  reverseChargeVatRate Decimal        @default(7) @db.Decimal(5, 2)
  dtaCountry           String?        @db.VarChar(2)

  // PND.54 — withholding tax on payments abroad (set when WHT applies).
  foreignWhtType    ForeignWhtType?
  foreignWhtBorneBy ForeignWhtBorneBy?
  foreignWhtRate    Decimal?           @db.Decimal(5, 2)

  // F4 — billing-name guard / capitalize-as-intangible / prepaid window
  billedToName               String?   @db.VarChar(200)
  billingNameMismatch        Boolean   @default(false)
  treatAsIntangible          Boolean   @default(false)
  treatAsPrepaid             Boolean   @default(false)
  intangibleUsefulLifeMonths Int?
  serviceStart               DateTime?
  serviceEnd                 DateTime?

  originalFileName String  @db.VarChar(300)
  storedPath       String  @db.VarChar(500)
  mimeType         String  @db.VarChar(100)
  sizeBytes        Int
  sha256           String? @db.VarChar(64)

  uploadedBy   String?
  reviewedBy   String?
  reviewedAt   DateTime?
  accountedBy  String?
  accountedAt  DateTime?
  rejectReason String?   @db.Text

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  expenseRecord ExpenseRecord?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status, createdAt])
  @@index([companyId, vendorId])
  @@index([companyId, proposedVendorTaxId])
  @@index([sha256])
}

model ExpenseRecord {
  id        String              @id @default(cuid())
  companyId String
  receiptId String              @unique
  vendorId  String
  projectId String?
  status    ExpenseRecordStatus @default(RECORDED)

  expenseDate    DateTime
  documentNumber String?  @db.VarChar(100)
  category       String?  @db.VarChar(100)
  note           String?  @db.Text

  subtotal             Decimal @default(0) @db.Decimal(18, 2)
  vatAmount            Decimal @default(0) @db.Decimal(18, 2)
  withholdingTaxAmount Decimal @default(0) @db.Decimal(18, 2)
  grandTotal           Decimal @default(0) @db.Decimal(18, 2)

  // Foreign expense snapshot (denormalized from the receipt at account time).
  isForeign       Boolean        @default(false)
  expenseNature   ExpenseNature?
  currency        String         @default("THB") @db.VarChar(3)
  fxRate          Decimal        @default(1) @db.Decimal(18, 6)
  foreignSubtotal Decimal?       @db.Decimal(18, 2)
  foreignWhtType    ForeignWhtType?
  foreignWhtBorneBy ForeignWhtBorneBy?
  foreignWhtRate    Decimal?           @db.Decimal(5, 2)
  treatAsIntangible Boolean            @default(false)
  treatAsPrepaid    Boolean            @default(false)
  serviceStart      DateTime?
  serviceEnd        DateTime?

  recordedBy String?
  recordedAt DateTime @default(now())

  company    Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  receipt    ExpenseReceipt @relation(fields: [receiptId], references: [id], onDelete: Restrict)
  vendor     Partner        @relation("ExpenseRecordVendor", fields: [vendorId], references: [id])
  project    Project?       @relation("ProjectExpenses", fields: [projectId], references: [id])
  fixedAsset FixedAsset?    @relation("ExpenseRecordFixedAsset")
  foreignTaxObligations ForeignTaxObligation[]
  prepaidScheduleEntries PrepaidScheduleEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, vendorId, expenseDate])
  @@index([companyId, status, expenseDate])
  @@index([companyId, projectId])
}

/// Self-assessed foreign-payment tax tied to an accounted ExpenseRecord.
/// PP36_VAT: 7% VAT the Thai payer must remit on a foreign service used in
/// Thailand (reverse charge). The receipt itself stays VAT=0; this row tracks
/// the separate obligation and, once filed, posts Dr Input VAT / Cr Cash and
/// snapshots a VatRecord(INPUT) in the filing period so it flows into PP.30.
/// PND54_WHT: reserved for Phase F3 (withholding tax on payments abroad).
model ForeignTaxObligation {
  id              String           @id @default(cuid())
  companyId       String
  expenseRecordId String
  kind            ForeignTaxKind
  status          ForeignTaxStatus @default(PENDING)

  baseAmount Decimal @db.Decimal(18, 2)
  rate       Decimal @db.Decimal(5, 2)
  taxAmount  Decimal @db.Decimal(18, 2)

  // The expense's own period vs. the period the form is due / VAT is claimable
  // (PP.36 for month M is filed in M+1; the input VAT credits in M+1's PP.30).
  expensePeriodYear  Int
  expensePeriodMonth Int
  filePeriodYear     Int
  filePeriodMonth    Int

  filedAt        DateTime?
  filedBy        String?
  journalEntryId String?
  note           String?   @db.Text

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  expenseRecord ExpenseRecord @relation(fields: [expenseRecordId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, kind, status])
  @@index([companyId, filePeriodYear, filePeriodMonth])
  @@index([expenseRecordId])
}

/// DTA withholding-rate reference for PND.54 (a suggestion, not authority —
/// the accountant confirms). country = ISO-2, or "*" for the no-DTA / Section 70
/// default. Seeded with a few common rows; editable as a config table.
model ForeignWhtRate {
  id         String         @id @default(cuid())
  country    String         @db.VarChar(2)
  incomeType ForeignWhtType
  rate       Decimal        @db.Decimal(5, 2)
  note       String?        @db.VarChar(200)

  @@unique([country, incomeType])
}

/// Straight-line monthly recognition schedule for a prepaid expense. One row
/// per service month; `runPrepaid` posts Dr Expense / Cr Prepaid for entries
/// due up to a given period and marks them RECOGNIZED (idempotent by status).
model PrepaidScheduleEntry {
  id              String                @id @default(cuid())
  companyId       String
  expenseRecordId String
  periodYear      Int
  periodMonth     Int
  amount          Decimal               @db.Decimal(18, 2)
  status          PrepaidScheduleStatus @default(PENDING)
  journalEntryId  String?
  recognizedAt    DateTime?

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  expenseRecord ExpenseRecord @relation(fields: [expenseRecordId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([companyId, status, periodYear, periodMonth])
  @@index([expenseRecordId])
}

model GeneratedPdf {
  id           String       @id @default(cuid())
  companyId    String
  documentType DocumentType
  documentId   String
  storedPath   String       @db.VarChar(500)
  sizeBytes    Int
  isPreview    Boolean      @default(false)
  dataVersion  Int          @default(1)
  generatedBy  String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([companyId, documentType, documentId])
}

/// Persisted Accountant Pack export (PRD §18/§20). Each export writes the ZIP
/// to disk and records this row so the operator can re-download it later and
/// see export history per period. The pack is only ever built from a LOCKED
/// period, so the file is a stable point-in-time snapshot.
model ExportBatch {
  id          String   @id @default(cuid())
  companyId   String
  year        Int
  month       Int
  fileName    String   @db.VarChar(200)
  storedPath  String   @db.VarChar(500)
  sizeBytes   Int
  fileCount   Int      @default(0)
  generatedBy String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([companyId, year, month])
  @@index([companyId, createdAt])
}

// ============================================================================
// Phase 2 Schema Foundation
// ============================================================================

model Project {
  id          String        @id @default(cuid())
  companyId   String
  code        String?       @db.VarChar(32)
  name        String        @db.VarChar(200)
  customerId  String?
  status      ProjectStatus @default(ACTIVE)
  description String?       @db.Text
  startDate   DateTime?
  endDate     DateTime?
  budget      Decimal?      @db.Decimal(18, 2)
  note        String?       @db.Text

  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer    Partner?        @relation("ProjectCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  expenses    ExpenseRecord[] @relation("ProjectExpenses")
  fixedAssets FixedAsset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, code])
  @@index([companyId, status])
  @@index([companyId, customerId])
}

model Payment {
  id          String           @id @default(cuid())
  companyId   String
  direction   PaymentDirection
  partnerId   String
  paymentDate DateTime
  amount      Decimal          @db.Decimal(18, 2)
  whtAmount   Decimal          @default(0) @db.Decimal(18, 2)
  method      PaymentMethod    @default(CASH)
  reference   String?          @db.VarChar(100)
  bankAccount String?          @db.VarChar(100)
  note        String?          @db.Text
  status      PaymentStatus    @default(COMPLETED)

  sourceType String? @db.VarChar(40)
  sourceId   String?

  recordedBy String?
  voidedBy   String?
  voidedAt   DateTime?
  voidReason String?   @db.Text

  company   Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  partner   Partner               @relation("PaymentPartner", fields: [partnerId], references: [id])
  whtRecord WithholdingTaxRecord? @relation("PaymentWht")
  bankMatch BankStatementLine?    @relation("BankMatchedPayment")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, direction, paymentDate])
  @@index([companyId, partnerId])
  @@index([companyId, status])
  @@index([sourceType, sourceId])
}

model JournalEntry {
  id          String             @id @default(cuid())
  companyId   String
  entryDate   DateTime
  description String             @db.Text
  status      JournalEntryStatus @default(POSTED)
  sourceType  JournalSourceType
  sourceId    String?
  totalDebit  Decimal            @default(0) @db.Decimal(18, 2)
  totalCredit Decimal            @default(0) @db.Decimal(18, 2)
  periodYear  Int
  periodMonth Int

  postedBy   String?
  postedAt   DateTime?
  voidedBy   String?
  voidedAt   DateTime?
  voidReason String?   @db.Text

  company Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines   JournalEntryLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, entryDate])
  @@index([companyId, periodYear, periodMonth])
  @@index([companyId, sourceType, sourceId])
  @@index([companyId, status])
}

model JournalEntryLine {
  id             String  @id @default(cuid())
  journalEntryId String
  lineNumber     Int
  accountCode    String  @db.VarChar(20)
  accountName    String  @db.VarChar(120)
  debit          Decimal @default(0) @db.Decimal(18, 2)
  credit         Decimal @default(0) @db.Decimal(18, 2)
  partnerId      String?
  projectId      String?
  description    String? @db.Text

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@unique([journalEntryId, lineNumber])
  @@index([journalEntryId])
  @@index([accountCode])
  @@index([partnerId])
  @@index([projectId])
}

model AccountingPeriod {
  id        String                 @id @default(cuid())
  companyId String
  year      Int
  month     Int
  status    AccountingPeriodStatus @default(OPEN)
  closedAt  DateTime?
  closedBy  String?
  lockedAt  DateTime?
  lockedBy  String?
  note      String?                @db.Text

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, year, month])
  @@index([companyId, status])
}

model VatRecord {
  id             String        @id @default(cuid())
  companyId      String
  recordType     VatRecordType
  sourceType     String        @db.VarChar(40)
  sourceId       String
  documentDate   DateTime
  documentNumber String?       @db.VarChar(100)
  partnerName    String        @db.VarChar(200)
  partnerTaxId   String?       @db.VarChar(20)
  baseAmount     Decimal       @db.Decimal(18, 2)
  vatRate        Decimal       @db.Decimal(5, 2)
  vatAmount      Decimal       @db.Decimal(18, 2)
  periodYear     Int
  periodMonth    Int

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([companyId, sourceType, sourceId])
  @@index([companyId, recordType, periodYear, periodMonth])
}

model WithholdingTaxRecord {
  id           String        @id @default(cuid())
  companyId    String
  recordType   WhtRecordType
  paymentId    String?       @unique
  sourceType   String        @db.VarChar(40)
  sourceId     String
  paidAt       DateTime
  partnerName  String        @db.VarChar(200)
  partnerTaxId String?       @db.VarChar(20)
  baseAmount   Decimal       @db.Decimal(18, 2)
  rate         Decimal       @db.Decimal(5, 2)
  whtAmount    Decimal       @db.Decimal(18, 2)
  certNumber   String?       @db.VarChar(100)
  category     String?       @db.VarChar(100)
  periodYear   Int
  periodMonth  Int

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payment Payment? @relation("PaymentWht", fields: [paymentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([companyId, recordType, periodYear, periodMonth])
}

model RiskItem {
  id          String         @id @default(cuid())
  companyId   String
  type        RiskItemType
  level       RiskLevel
  status      RiskItemStatus @default(OPEN)
  entityType  String?        @db.VarChar(40)
  entityId    String?
  title       String         @db.VarChar(300)
  description String?        @db.Text
  detectedAt  DateTime       @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?
  resolution  String?        @db.Text

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status, level])
  @@index([companyId, type])
  @@index([entityType, entityId])
}

model AiSuggestion {
  id              String             @id @default(cuid())
  companyId       String
  type            AiSuggestionType
  status          AiSuggestionStatus @default(PENDING)
  sourceType      String?            @db.VarChar(40)
  sourceId        String?
  attachmentId    String?
  confidence      Decimal?           @db.Decimal(5, 4)
  payload         Json
  model           String?            @db.VarChar(100)
  acceptedBy      String?
  acceptedAt      DateTime?
  rejectionReason String?            @db.Text
  // Soft-delete: when the operator removes a row from AI Inbox we keep the
  // record (for audit) but exclude it from list/dedup queries. ACCEPTED rows
  // can't be soft-deleted because they're the only link back to the staged
  // suggestion that produced an existing ExpenseReceipt.
  deletedAt       DateTime?
  deletedBy       String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status, createdAt])
  @@index([companyId, type, status])
  @@index([sourceType, sourceId])
  @@index([companyId, deletedAt])
}

model InventoryMovement {
  id            String                @id @default(cuid())
  companyId     String
  productId     String
  type          InventoryMovementType
  quantity      Decimal               @db.Decimal(18, 4)
  movementDate  DateTime
  unitCost      Decimal?              @db.Decimal(18, 2)
  totalCost     Decimal?              @db.Decimal(18, 2)
  referenceType String?               @db.VarChar(40)
  referenceId   String?
  note          String?               @db.Text
  recordedBy    String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([companyId, productId, movementDate])
  @@index([companyId, type])
  @@index([referenceType, referenceId])
}

model FixedAsset {
  id               String           @id @default(cuid())
  companyId        String
  code             String?          @db.VarChar(32)
  name             String           @db.VarChar(200)
  category         String           @db.VarChar(100)
  status           FixedAssetStatus @default(ACTIVE)
  acquiredAt       DateTime
  cost             Decimal          @db.Decimal(18, 2)
  salvageValue     Decimal          @default(0) @db.Decimal(18, 2)
  usefulLifeMonths Int
  accumulatedDepr  Decimal          @default(0) @db.Decimal(18, 2)
  bookValue        Decimal          @db.Decimal(18, 2)
  disposedAt       DateTime?
  disposalReason   String?          @db.Text

  expenseRecordId String? @unique
  projectId       String?

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  expenseRecord ExpenseRecord? @relation("ExpenseRecordFixedAsset", fields: [expenseRecordId], references: [id], onDelete: SetNull)
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, code])
  @@index([companyId, status])
  @@index([companyId, category])
}

model BankStatementLine {
  id               String            @id @default(cuid())
  companyId        String
  bankAccount      String            @db.VarChar(100)
  postedAt         DateTime
  side             BankStatementSide
  amount           Decimal           @db.Decimal(18, 2)
  balance          Decimal?          @db.Decimal(18, 2)
  description      String            @db.Text
  reference        String?           @db.VarChar(100)
  matchedPaymentId String?           @unique
  matchedAt        DateTime?
  matchConfidence  Decimal?          @db.Decimal(5, 4)
  importBatchId    String?           @db.VarChar(64)

  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  matchedPayment Payment? @relation("BankMatchedPayment", fields: [matchedPaymentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, bankAccount, postedAt])
  @@index([importBatchId])
}
